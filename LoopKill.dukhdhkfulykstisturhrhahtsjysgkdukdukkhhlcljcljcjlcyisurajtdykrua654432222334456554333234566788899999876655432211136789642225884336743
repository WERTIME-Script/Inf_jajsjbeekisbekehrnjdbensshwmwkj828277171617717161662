-- // VÒNG LẶP CHÍNH //
RunService.Heartbeat:Connect(function()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not (hrp and SelectedTarget and SelectedTarget.Character and SelectedTarget.Character:FindFirstChild("HumanoidRootPart")) then return end
    local tP = SelectedTarget.Character.HumanoidRootPart
    local tPos = Smart and (tP.Position + tP.Velocity * 0.15) or tP.Position
    local finalPos
    if Smart then
        local rTick = tick() * 350
        finalPos = tPos + Vector3.new(math.sin(rTick)*(OrbitDist+math.random(-2,2)), math.sin(tick()*100)*6, math.cos(rTick)*(OrbitDist+math.random(-2,2)))
    else
        if PosMode == 1 then local t = tick()*OrbitSpeed; finalPos = tPos + Vector3.new(math.cos(t)*OrbitDist, 0, math.sin(t)*OrbitDist)
        elseif PosMode == 2 then finalPos = tPos + Vector3.new(0, OrbitDist + 3, 0)
        else finalPos = tPos - Vector3.new(0, OrbitDist, 0) end
    end
    hrp.CFrame = CFrame.lookAt(finalPos, tPos); hrp.Velocity = Vector3.new(0, 0.01, 0)
    if CamL and not MenuDragging then 
        Camera.CameraType = Enum.CameraType.Scriptable; 
        Camera.CFrame = CFrame.new(tPos) * CFrame.Angles(0, CamRotX, 0) * CFrame.Angles(CamRotY, 0, 0) * CFrame.new(0, 2, CamDist) 
    end
    if AntiVoid and hrp.Position.Y < -500 then hrp.CFrame = CFrame.new(hrp.Position.X, 500, hrp.Position.Z); hrp.Velocity = Vector3.zero end
end)

UserInputService.InputBegan:Connect(function(i, g) if g then return end if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = true; if CamL then camTouchId = i; lastCamPos = i.Position end end end)
UserInputService.InputChanged:Connect(function(i) if MenuDragging then return end if CamL and i == camTouchId then local d = i.Position - lastCamPos; CamRotX, CamRotY = CamRotX - d.X * 0.008, math.clamp(CamRotY - d.Y * 0.008, -1.3, 1.3) lastCamPos = i.Position end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end end)
  
