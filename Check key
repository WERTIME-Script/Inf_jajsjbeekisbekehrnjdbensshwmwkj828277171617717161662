local function FadeOutAndDestroy()
    isLock = true
    local info = TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    TweenService:Create(MainFrame, info, {BackgroundTransparency = 1}):Play()
    TweenService:Create(UIStroke, info, {Transparency = 1}):Play()
    for _, v in pairs(MainFrame:GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextBox") or v:IsA("TextButton") then
            TweenService:Create(v, info, {TextTransparency = 1, BackgroundTransparency = 1}):Play()
        end
    end
    task.wait(0.6)
    ScreenGui:Destroy()
end

