-- [ FAIL FEEDBACK (RUNG + Äá») ] --
local function Denied()
    local origin = MainFrame.Position
    local start = tick()
    UIStroke.Color = COLOR_RED; CheckBtn.BackgroundColor3 = COLOR_RED
    CheckBtn.Text = "<font face='RobotoMono' size='13'><b>! ERROR_KEY</b></font>"
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if tick() - start < 0.4 then
            MainFrame.Position = origin + UDim2.new(0, math.random(-7, 7), 0, math.random(-7, 7))
        else
            MainFrame.Position = origin; UIStroke.Color = COLOR_BLURPLE
            CheckBtn.BackgroundColor3 = COLOR_BLURPLE
            CheckBtn.Text = "<font face='RobotoMono' size='13'><b>> RUN_AUTH</b></font>"; isLock = false; conn:Disconnect()
        end
    end)
end

